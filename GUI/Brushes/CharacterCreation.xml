<Brushes>
  <Brush Name="Stage.Text" FontColor="#FFFFFFFF">
    <Animations>
      <Animation Name="FontHoverAnimation" Duration="0.1">
      </Animation>
      <Animation Name="FontPressedAnimation" Duration="0.05">
      </Animation>
      <Animation Name="FontDefaultAnimation" Duration="0.1">
      </Animation>
    </Animations>
    <Layers>
      <BrushLayer Name="Default" Color="#FFFFFFFF" />
      <BrushLayer Name="HoverLayer" Color="#FFFF00FF" />
    </Layers>
    <Styles>
      <Style Name="Default" FontColor="#FFFFFFFF" TextGlowColor="#FFFFFF11" TextGlowRadius="0.1" AnimationToPlayOnBegin="FontDefaultAnimation" FontSize="36">
        <BrushLayer Name="Default" FontColor="#FFFFFFFF" />
      </Style>
      <Style Name="Hovered" FontColor="#F3C697FF" TextGlowColor="#F3C69711" AnimationToPlayOnBegin="FontHoverAnimation">
        <BrushLayer Name="HoverLayer" FontColor="#F3C697FF" />
      </Style>
      <Style Name="Pressed" FontColor="#B57F5CFF" TextGlowColor="#B57F5C11" AnimationToPlayOnBegin="FontPressedAnimation">
        <BrushLayer Name="Default" />
      </Style>
      <Style Name="Disabled" TextGlowColor="#00000000" TextAlphaFactor="0.35">
        <BrushLayer Name="Default" />
      </Style>
      <Style Name="Selected" FontColor="#F3C697FF" TextGlowColor="#AA8A6955" TextGlowRadius="0.01">
        <BrushLayer Name="Default" />
      </Style>
    </Styles>
  </Brush>

