<Brushes>
  <Brush Name="InitialMenuButtonBrush" FontColor="#FFFFFFFF" Font="Galahad" TransitionDuration="0.3">
    <Layers>
      <BrushLayer Name="Default" Color="#FFFFFFFF" />
    </Layers>
    <Styles>
      <Style Name="Default" FontColor="#831212FF" TextGlowColor="#000000FF" TextGlowRadius="0.3" FontSize="32">
        <BrushLayer Name="Default" FontColor="#831212FF" />
      </Style>
      <Style Name="Hovered" FontColor="#FFFFFFFF" TextGlowColor="#000000FF" TextGlowRadius="0.3">
        <BrushLayer Name="Default" FontColor="#FFFFFFFF" />
      </Style>
      <Style Name="Pressed" FontColor="#FFFFFFFF" TextGlowColor="#000000FF" TextGlowRadius="0.3">
        <BrushLayer Name="Default" FontColor="#FFFFFFFF"/>
      </Style>
      <Style Name="Disabled" TextGlowColor="#00000000" TextAlphaFactor="0.35">
        <BrushLayer Name="Default" />
      </Style>
    </Styles>
    <SoundProperties>
      <StateSounds>
      </StateSounds>
      <EventSounds>
        <EventSound EventName="Click" Audio="default" />
      </EventSounds>
    </SoundProperties>
  </Brush>
  <Brush Name="HoverIndicatorBrush" FontColor="#FFFFFFFF" TransitionDuration="0.225">
    <Layers>
      <BrushLayer Name="Default" Sprite="SPGeneral\SPScoreboard\leader_crown_icon"/>
    </Layers>
    <Styles>
      <Style Name="Default" FontSize="36">
        <BrushLayer Name="Default" AlphaFactor="0" />
      </Style>
      <Style Name="Disabled">
        <BrushLayer Name="Default" AlphaFactor="0"/>
      </Style>
      <Style Name="Hovered">
        <BrushLayer Name="Default" AlphaFactor="1" ColorFactor="2" Color="#FFFFFFFF"/>
      </Style>
      <Style Name="Pressed">
        <BrushLayer Name="Default" AlphaFactor="0.15" ColorFactor="2" Color="#ff0000FF"/>
      </Style>
    </Styles>
  </Brush>
  <Brush Name="HoverIndicatorBrushFlipped" FontColor="#FFFFFFFF" TransitionDuration="0.225">
    <Layers>
      <BrushLayer Name="Default" HorizontalFlip="true" Sprite="SPGeneral\SPScoreboard\leader_crown_icon"/>
    </Layers>
    <Styles>
      <Style Name="Default" FontSize="36">
        <BrushLayer Name="Default" AlphaFactor="0" />
      </Style>
      <Style Name="Disabled">
        <BrushLayer Name="Default" AlphaFactor="0"/>
      </Style>
      <Style Name="Hovered">
        <BrushLayer Name="Default" AlphaFactor="1" ColorFactor="2" Color="#FFFFFFFF"/>
      </Style>
      <Style Name="Pressed">
        <BrushLayer Name="Default" AlphaFactor="0.15" ColorFactor="2" Color="#ff0000FF"/>
      </Style>
    </Styles>
  </Brush>
  <Brush Name="InitialMenu.Additional.Option" Font="Galahad">
    <Styles>
      <Style Name="Default" FontColor="#F4E1C4FF" TextGlowColor="#000000FF" TextOutlineColor="#000000FF" TextOutlineAmount="0.1" TextGlowRadius="0" TextBlur="0" FontSize="28" />
    </Styles>
  </Brush>
  <Brush Name="InitialMenu.Logo">
    <Layers>
      <BrushLayer Name="Default" Sprite="General\InitialMenu\main_menu_logo" />
    </Layers>
  </Brush>
   <Brush Name="InitialMenu.Logo.WarSails">
    <Layers>
      <BrushLayer Name="Default" Sprite="" Color="#EEE0C7FF" />
    </Layers>
  </Brush>
</Brushes>